{
    "name": "dron_sim:latest",
    "image": "dron_sim",
    "remoteUser": "karol",
    "runArgs": [
        "--network=host",
        "--ipc=host",
        "--gpus=all",
        "--volume=/tmp/.X11-unix:/tmp/.X11-unix",
        "--privileged",
        "--device=/dev/dri",
        "--group-add=video",
        "--volume=${env:HOME}/.Xauthority:/home/karol/.Xauthority:ro",
        "--volume=/home/karol/.gz:/home/karol/.gz",
        "--volume=${localWorkspaceFolder}/.qgc-config:/home/karol/.config/QGroundControl:rw",
        "--volume=${localWorkspaceFolder}/../hitnet_venv:/home/karol/venv"
    ],
    "workspaceMount": "source=${localWorkspaceFolder}/,target=/home/karol/ws,type=bind,consistency=cached",
    "workspaceFolder": "/home/karol/ws",
    "containerEnv": {
        "XAUTHORITY": "/home/karol/.Xauthority",
        "DISPLAY": "${localEnv:DISPLAY}",
        "ROS_DOMAIN_ID": "0",
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "all",
        "__NV_PRIME_RENDER_OFFLOAD": "1",
        "__GLX_VENDOR_LIBRARY_NAME": "nvidia",
        "__EGL_VENDOR_LIBRARY_FILENAMES": "/usr/share/glvnd/egl_vendor.d/10_nvidia.json",
        "QT_QPA_PLATFORM": "xcb",
        "LIBGL_ALWAYS_INDIRECT": "0"
    },
    "postStartCommand": "/${containerWorkspaceFolder}/scripts/post_start.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-iot.vscode-ros",
                "twxs.cmake",
                "ms-vscode.cpptools-extension-pack",
                "vivaxy.vscode-conventional-commits"
            ]
        }
    }
}
